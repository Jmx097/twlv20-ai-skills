#!/usr/bin/env bash
set -euo pipefail
umask 077
set -a
source /root/.secrets/b2-backup.env
set +a
STAMP="$(date -u +%Y-%m-%d-%H%MUTC)"
DAY="$(date -u +%Y-%m-%d)"
WORK="$(mktemp -d /var/backups/twlv20-postgres/run.XXXXXX)"
trap 'rm -rf "$WORK"' EXIT
BASE="weekly-postgres-${STAMP}.sql"
PLAIN="$WORK/$BASE"
GZ="$PLAIN.gz"
ENC="$GZ.gpg"
OBJ="${B2_OBJECT_PREFIX}/${DAY}/${BASE}.gz.gpg"
LOG=/var/log/twlv20/postgres-backup.log
{
  echo "[$(date -u --iso-8601=seconds)] starting backup $OBJ"
  sudo -u postgres pg_dump --format=plain --no-owner --no-privileges --dbname=twlv20 > "$PLAIN"
  gzip -9 "$PLAIN"
  gpg --batch --yes --symmetric --cipher-algo AES256 --pinentry-mode loopback --passphrase-file /root/.secrets/pg-backup-gpg.pass --output "$ENC" "$GZ"
  /usr/local/sbin/twlv20-pg-b2.py upload "$ENC" "$OBJ"
  /usr/local/sbin/twlv20-pg-b2.py retention "$B2_OBJECT_PREFIX/" "$B2_RETENTION_COUNT"
  echo "[$(date -u --iso-8601=seconds)] backup complete $OBJ"
} | tee -a "$LOG"
