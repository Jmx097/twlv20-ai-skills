#!/usr/bin/env bash
set -euo pipefail
TO="ai@twlv20.com"
SUBJECT="Twlv20 Postgres backup failed on $(hostname -f 2>/dev/null || hostname)"
BODY="Twlv20 weekly Postgres backup failed on $(hostname) at $(date -u --iso-8601=seconds). Check: journalctl -u twlv20-postgres-backup.service -n 200 --no-pager"
if command -v mail >/dev/null 2>&1; then printf '%s\n' "$BODY" | mail -s "$SUBJECT" "$TO" && exit 0; fi
if command -v sendmail >/dev/null 2>&1; then { printf 'To: %s\nSubject: %s\n\n%s\n' "$TO" "$SUBJECT" "$BODY"; } | sendmail -t && exit 0; fi
logger -t twlv20-postgres-backup-alert "$SUBJECT - $BODY"
exit 1

