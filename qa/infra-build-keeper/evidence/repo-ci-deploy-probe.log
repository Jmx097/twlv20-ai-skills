name: CI

on:
  pull_request:
  push:
    branches: [main]

jobs:
  runtime:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: runtime
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '22'
          cache: npm
          cache-dependency-path: runtime/package-lock.json
      - run: npm ci
      - run: npm run lint
      - run: npm run build
      - run: npm test

  schema-smoke:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Check required infra files
        run: |
          test -s infra/schema.sql
          test -s infra/tests/rls_isolation.sql
          grep -q "ENABLE ROW LEVEL SECURITY" infra/schema.sql
          grep -q "RLS isolation test passed" infra/tests/rls_isolation.sql

---deploy---
name: Deploy

on:
  push:
    branches: [main]
  workflow_dispatch:

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Deploy on droplet
        uses: appleboy/ssh-action@v1.2.0
        with:
          host: ${{ secrets.DROPLET_HOST }}
          username: ${{ secrets.DROPLET_USER }}
          key: ${{ secrets.DROPLET_SSH_KEY }}
          script: |
            set -euo pipefail
            cd /opt/twlv20-ai-skills
            git fetch origin main
            git reset --hard origin/main
            git clean -fdx -e runtime/node_modules/
            cd runtime
            npm ci
            npm run build
            sudo -n systemctl restart twlv20-ai-runtime.service
            sudo -n systemctl status twlv20-ai-runtime.service

